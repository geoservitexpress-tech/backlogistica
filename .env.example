# Supabase → Project Settings → Database → Connection string → URI
# Para apps servidoras suele usarse el pooler (puerto 6543, modo transaction).
# Si usas el pooler en modo "Transaction", añade también: ?pgbouncer=true
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require

# Solo desarrollo: crea/altera tablas según entidades (no usar en producción).
TYPEORM_SYNC=false

# Supabase exige TLS; pon false solo en entornos locales muy concretos.
DATABASE_SSL=true

# Puerto HTTP (opcional)
PORT=3000
